# development | production. In production, config.Load() fails fast unless
# JWT_SECRET, OAUTH_CLIENT_ID/SECRET, an https:// OAUTH_REDIRECT_URL/FRONTEND_URL/
# API_BASE_URL, CORS_ALLOWED_ORIGINS, and SMTP_HOST/USERNAME/PASSWORD are all
# set to real values.
APP_ENV=development
PORT=8080
# Local: the postgres service in docker-compose.yml. Neon: use the DIRECT
# (non "-pooler") connection string from the Neon dashboard with
# sslmode=require - this app manages its own connection pool via pgx directly
# (internal/platform/db/db.go), and Neon's pooled/PgBouncer endpoint runs in
# transaction-pooling mode, which doesn't reliably support prepared
# statements without extra config.
DB_DSN=postgres://sli:sli@localhost:5432/sli_db?sslmode=disable
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRY_HOURS=1
JWT_REFRESH_EXPIRY_DAYS=7
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:8080/api/auth/google/callback
ALLOWED_DOMAIN=somaiya.edu
FRONTEND_URL=http://localhost:3000
# This server's own public base URL (no trailing slash) - used to build the
# clickable link inside magic-link emails (must hit this backend's
# /api/auth/magic-link/verify directly, not the frontend).
API_BASE_URL=http://localhost:8080
# Comma-separated list of origins allowed to make credentialed CORS requests.
# Defaults to FRONTEND_URL if unset.
CORS_ALLOWED_ORIGINS=http://localhost:3000
PDF_STORAGE_PATH=./data/marksheets
REPORT_EDIT_WINDOW_HOURS=24
RATE_LIMIT_AUTH=100
RATE_LIMIT_PUBLIC=20
RATE_LIMIT_DEFAULT=100

# SMTP - used to send magic-link sign-in emails and all other outbound
# notification email (report submitted, industry review link, reminders).
# Works with Gmail SMTP, SendGrid, Mailgun, SES, Mailtrap, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=no-reply@somaiya.edu
SMTP_FROM_NAME=SLI Internship Portal
# How long a magic-link sign-in token stays valid before it must be re-requested.
MAGIC_LINK_EXPIRY_MINUTES=15
